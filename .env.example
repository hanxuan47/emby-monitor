# ============================================================
# Emby Monitor — Environment Configuration
# ============================================================
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================

# ── 数据库 ─────────────────────────────────────────────────
# SQLite 数据库路径（Docker 中已自动配置，无需修改）
# DATABASE_URL=sqlite+aiosqlite:///data/emby_monitor.db

# ── 加密 ─────────────────────────────────────────────────
# 加密密钥，用于加密存储 API Key、TG Token、SMTP 密码等敏感信息
# ⚠️ DOCKER 必须设置固定密钥，否则容器重建后数据无法解密！
# 生成命令: python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# ENCRYPTION_KEY=

# 自定义密钥文件路径（不设置则自动从 DATABASE_URL 同目录推导）
# ENCRYPTION_KEY_FILE=/path/to/.encryption_key

# ── CORS ─────────────────────────────────────────────────
# 允许的前端来源（逗号分隔，默认为 * 允许所有）
# 生产环境建议设置为具体域名
# CORS_ORIGINS=https://your-domain.com

# ── TMDB API ──────────────────────────────────────────────
# 用于影视发现功能（如果不填，影视发现功能不可用）
# 免费申请: https://www.themoviedb.org/settings/api
# TMDB_API_KEY=

# ── Telegram Bot ───────────────────────────────────────────
# 用于 TG 通知、用户绑定、密码重置验证码
# 在面板设置页面配置，也可通过环境变量预置
# TG_BOT_TOKEN=

# ── SMTP 邮件 ──────────────────────────────────────────────
# 用于邮件通知、密码重置
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@example.com

# ── 高德地图 ──────────────────────────────────────────────
# 用于用户 IP 地图展示
# 申请地址: https://console.amap.com/dev/key/app
# AMAP_JS_KEY=

# ── AI 分析 ──────────────────────────────────────────────
# LLM 提供商 API Key（用于 AI 用户行为分析）
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=

# ── 其他 ─────────────────────────────────────────────────
# 时区
# TZ=Asia/Shanghai

# 前端 API 基础路径（生产环境通常留空即可）
# VITE_API_BASE=
